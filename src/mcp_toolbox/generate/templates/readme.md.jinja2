## Quick Start

```bash
# Install dependencies
pip install -e .

# Set environment variables
export {{ server_name | upper }}_BASE_URL="{{ base_url }}"
{% if auth.auth_type.value == "bearer" %}export {{ auth.env_var_name }}="your-bearer-token"
{% elif auth.auth_type.value == "oauth2" %}export {{ auth.env_var_name }}="your-access-token"
export {{ auth.client_id_env_var }}="your-client-id"
export {{ auth.client_secret_env_var }}="your-client-secret"
export {{ server_name | upper }}_TOKEN_URL="{{ auth.token_url }}"
{% elif auth.auth_type.value in ["api_key_header", "api_key_query", "api_key_cookie"] %}export {{ auth.env_var_name }}="your-api-key"
{% elif auth.auth_type.value == "basic" %}export {{ server_name | upper }}_USERNAME="your-username"
export {{ server_name | upper }}_PASSWORD="your-password"
{% endif %}
# Optional reliability tuning
export {{ server_name | upper }}_RETRY_MAX_ATTEMPTS="2"
export {{ server_name | upper }}_RETRY_BACKOFF_SECONDS="0.5"
export {{ server_name | upper }}_RETRY_UNSAFE_METHODS="false"

# Run the server
{{ server_name }}-mcp-server
```


[project]
name = "{{ server_name }}-mcp-server"
version = "0.2.0"
description = "MCP server for {{ server_title }}"
requires-python = ">=3.10"
dependencies = [
 "mcp[cli]>=1.26.0",
 "httpx>=0.27.1",
 "pydantic>=2.5",
]

[project.scripts]
{{ server_name }}-mcp-server = "{{ package_name }}.server:main"

[build-system]
requires = ["hatchling"]
build-backend = "hatchling.build"
